<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.learning.healthpro.mapper.UserMapper">
    <select id="findPassWordByPhone" resultType="String">
        select password from user where phone = #{id}
    </select>

    <select id="countByPhone" resultType="Long">
        select count(*) from user  where phone = #{phone}
    </select>

    <select id="findIdByPhone" resultType="int">
        select id from user where phone = #{phone}
    </select>

    <select id="selectById" resultType="com.learning.healthpro.entity.User">
        select name,phone,email,age,gender from user where id = #{id}
    </select>

    <insert id="insert">
        insert into user(name,password,phone,email) values(#{name},#{password},#{phone},#{email})
    </insert>

    <update id="UpdateUserInfo">
        update user
        <set>
            <if test="name != none and name != ''">
                name = #{name}
            </if>
            <if test="phone != none and phone != ''">
                phone = #{phone}
            </if>
            <if test="email != none and email != ''">
                email = #{email}
            </if>
            <if test="age != none and age != ''">
                age = #{age}
            </if>
            <if test="gender != none and gender != ''">
                gender = #{gender}
            </if>
        </set>
        where id = #{id}
    </update>
</mapper>
